{
  "environment": "development",
  "port": "8890",
  "debug": true,
  "log_level": "debug",
  "cors_allowed_origins": [
    "http://localhost:3000",
    "http://localhost:8080",
    "http://localhost:8890"
  ],
  "cors_allowed_methods": [
    "GET",
    "POST",
    "PUT",
    "DELETE",
    "OPTIONS"
  ],
  "cors_allowed_headers": [
    "Origin",
    "Content-Type",
    "Accept",
    "Authorization",
    "X-Requested-With"
  ],
  "logging": {
    "file_enabled": true,
    "file_directory": "logs",
    "retention_days": 7
  }
}
